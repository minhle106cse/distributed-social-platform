# ==============================================================================
# ENVIRONMENT VARIABLES - DEVELOPMENT (LOCAL DOCKER)
# ==============================================================================
# This file is used for local development running on docker-compose.

# --- DATABASE (POSTGRESQL LOCAL DOCKER) ---
DB_HOST=localhost
DB_PORT=15432
DB_USER=root
DB_PASSWORD=rootpassword
# Docker compose inits this DB by default
CORE_DB_NAME=core_db
AUTH_DB_NAME=auth_db

# --- DATABASE URLS (FOR APPS) ---
CORE_DATABASE_URL="postgresql://root:rootpassword@localhost:15432/core_db?schema=public"
AUTH_DATABASE_URL="postgresql://root:rootpassword@localhost:15432/auth_db?schema=public"

# --- REDIS (LOCAL DOCKER) ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# --- KAFKA (LOCAL DOCKER) ---
KAFKA_BROKER_PORT=9092
KAFKA_CONTROLLER_PORT=9093

# --- ELASTICSEARCH (LOCAL DOCKER) ---
ELASTIC_PORT=9200
ELASTIC_USERNAME=elastic
ELASTIC_PASSWORD=changeme

# --- APP PORTS ---
AUTH_SERVICE_PORT=4001
CORE_API_PORT=4002

# --- SECRETS ---
JWT_ACCESS_SECRET=local-dev-jwt-access-secret-do-not-use-in-prod
JWT_REFRESH_SECRET=local-dev-jwt-refresh-secret-do-not-use-in-prod

# --- GRAFANA ---
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin
GRAFANA_PORT=3000

# --- UIs & DASHBOARDS ---
KAFKA_UI_USER=admin
KAFKA_UI_PASSWORD=admin
KAFKA_UI_PORT=8080
REDISINSIGHT_PORT=8001
KIBANA_PORT=5601
PROMETHEUS_PORT=9090

# --- API GATEWAY ---
API_GATEWAY_PORT=8000

# --- EXPORTERS ---
NODE_EXPORTER_PORT=9100
POSTGRES_EXPORTER_PORT=9187
REDIS_EXPORTER_PORT=9121
KAFKA_EXPORTER_PORT=9308
ELASTICSEARCH_EXPORTER_PORT=9114
NGINX_EXPORTER_PORT=9113
