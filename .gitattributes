# Normalize line endings → prevent EOL churn when files are regenerated by
# different environments (docker Linux builder writes LF, host Windows python
# writes CRLF). Without this, .ai/KNOWLEDGE_INDEX.md flips all lines every sync.
* text=auto eol=lf

# Generated / curated knowledge files — always LF (regenerated cross-env)
.ai/KNOWLEDGE_INDEX.md   text eol=lf
.ai/PROJECT_STATUS.md    text eol=lf
.ai/QUICK_REFERENCE.md   text eol=lf

# Scripts that must stay LF for shells / node
*.cjs  text eol=lf
*.py   text eol=lf
*.sh   text eol=lf
