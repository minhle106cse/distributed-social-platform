{
  "name": "distributed-social-platform",
  "version": "1.0.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "private": true,
  "packageManager": "npm@11.4.2",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "db:push": "turbo run db:push",
    "db:format": "turbo run db:format",
    "db:studio": "turbo run db:studio",
    "infra:up": "docker-compose up -d",
    "infra:down": "docker-compose down",
    "agent:up": "docker-compose -f docker-compose.agent.yml up -d",
    "agent:down": "docker-compose -f docker-compose.agent.yml down",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "format": "prettier --write \"**/*.{ts,tsx,md}\""
  },
  "keywords": [],
  "author": "minhle106cse",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "@types/node": "^25.0.10",
    "turbo": "^2.9.15"
  }
}
